# ─── Banco de dados ────────────────────────────────────────────────────────────
# Dev: SQLite (padrão). Produção: trocar o provider para "postgresql" em
# prisma/schema.prisma e usar a URL abaixo (ver README → "Migrar para PostgreSQL").
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://usuario:senha@host:5432/iso_manager?schema=public"

# ─── Autenticação (NextAuth / Auth.js v5) ──────────────────────────────────────
# Chave para assinar as sessões JWT. GERE UMA NOVA EM PRODUÇÃO (openssl rand -base64 32).
AUTH_SECRET="troque-esta-chave-em-producao"
NEXTAUTH_SECRET="troque-esta-chave-em-producao"

# URL pública da aplicação (usada nos links dos e-mails). Sem barra no final.
APP_URL="http://localhost:3000"

# ─── E-mail transacional (Resend) — OPCIONAL ───────────────────────────────────
# Sem estas variáveis, o app continua funcionando: os links de convite / redefinição
# de senha são exibidos na própria tela em vez de enviados por e-mail.
RESEND_API_KEY=""
EMAIL_FROM="ISO Manager <nao-responda@seu-dominio.com>"

# ─── Storage de evidências em nuvem (Vercel Blob) — OPCIONAL ────────────────────
# Sem esta variável, os arquivos são gravados em disco local (storage/uploads).
BLOB_READ_WRITE_TOKEN=""

# ─── Assistente de IA (Anthropic Claude) — OPCIONAL ────────────────────────────
# Sem a chave, os recursos de IA aparecem desabilitados na interface.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-6"
